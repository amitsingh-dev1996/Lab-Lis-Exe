  <appSettings>
    <add key="IntrumentId" value="57" />
    <!--
    TCP: TCP_HostIpAddress, TCP_HostPort, Server/Client
    Serial: SerialPortName, SerialBaudRate, SerialParity, SerialStopBits, SerialDataBits
